{
  "strykerConfig": {
    "project": "ai-native",
    "mutate": ["src/**/*.ts", "src/**/*.tsx"],
    "testRunner": "jest",
    "reporters": ["html", "clear-text", "progress"],
    "coverageAnalysis": "perTest",
    "timeoutMS": 600000,
    "timeoutFactor": 1.5,
    "maxConcurrentTestRunners": 4,
    "thresholds": {
      "high": 80,
      "low": 60,
      "break": 50
    }
  }
}
