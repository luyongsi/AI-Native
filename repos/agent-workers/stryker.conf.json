{
  "mutator": "javascript",
  "packageManager": "npm",
  "testRunner": "jest",
  "coverageAnalysis": "perTest",
  "thresholds": {
    "high": 80,
    "low": 60,
    "break": 50
  },
  "mutate": [
    "src/**/*.js",
    "src/**/*.ts",
    "src/**/*.jsx",
    "src/**/*.tsx",
    "!src/**/*.test.js",
    "!src/**/*.test.ts",
    "!src/**/*.test.jsx",
    "!src/**/*.test.tsx",
    "!src/**/*.spec.js",
    "!src/**/*.spec.ts",
    "!src/**/*.spec.jsx",
    "!src/**/*.spec.tsx"
  ],
  "reporters": [
    "html",
    "json",
    "progress",
    "dashboard"
  ],
  "timeoutMs": 5000,
  "timeoutFactor": 1.25,
  "concurrency": 4,
  "maxTestRunnerReuse": 1,
  "logLevel": "info"
}
